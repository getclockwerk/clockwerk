{
  "name": "clockwerk",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "docker compose up",
    "dev:down": "docker compose down",
    "dev:logs": "docker compose logs -f",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "eslint . && eslint --config apps/web/eslint.config.mjs apps/web/src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "bun run --filter @clockwerk/db migrate",
    "db:generate": "bun run --filter @clockwerk/db generate",
    "db:push": "docker compose exec -w /app/packages/db web bunx drizzle-kit push",
    "db:studio": "docker compose exec -w /app/packages/db web bunx drizzle-kit studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "scripts/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "eslint --config apps/web/eslint.config.mjs --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "9",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  }
}
